# Local development (SQLite file)
DATABASE_URL="file:./dev.db"

# Production on Vercel — use Turso (SQLite-compatible hosted DB)
# 1. Create a free DB at https://turso.tech
# 2. Run: turso db show <db-name> --url
# 3. Run: turso db tokens create <db-name>
# DATABASE_URL="libsql://your-db-name.turso.io"
# TURSO_AUTH_TOKEN="your-turso-auth-token"

# Public URL used in QR codes — set to your deployed domain before generating QRs for PPT slides.
# Example: https://codeace-awards.vercel.app
NEXT_PUBLIC_APP_URL="http://localhost:3000"

ALLOWED_EMAIL_DOMAIN="codeace.com"

# Admin login password (required in production)
APP_PASSWORD="Codeace@#2026"
