# ── Local development (SQLite file) ──
DATABASE_URL="file:./dev.db"

# ── Production on Vercel (REQUIRED — do NOT use file:./dev.db) ──
# 1. Create a free DB: https://turso.tech
# 2. turso db create codeace-awards
# 3. turso db show codeace-awards --url
# 4. turso db tokens create codeace-awards
# DATABASE_URL="libsql://codeace-awards-<org>.turso.io"
# TURSO_AUTH_TOKEN="your-turso-auth-token"

# Public URL used in QR codes — set to your deployed domain before generating QRs for PPT slides.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

ALLOWED_EMAIL_DOMAIN="codeace.com"

# Admin login password (required in production)
APP_PASSWORD="Codeace@#2026"
