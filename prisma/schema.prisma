generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Topic {
  id          Int         @id @default(autoincrement())
  title       String
  description String?
  order       Int         @default(0)
  presenters  Presenter[]
  sessions    Session[]
  createdAt   DateTime    @default(now())
}

model Presenter {
  id        Int       @id @default(autoincrement())
  name      String
  photo     String?
  topicId   Int
  topic     Topic     @relation(fields: [topicId], references: [id], onDelete: Cascade)
  scores    Score[]
  createdAt DateTime  @default(now())

  @@index([topicId])
}

model Score {
  id           Int       @id @default(autoincrement())
  presenterId  Int
  presenter    Presenter @relation(fields: [presenterId], references: [id], onDelete: Cascade)
  topicId      Int
  email        String
  rating       Int
  sessionToken String
  ipAddress    String?
  createdAt    DateTime  @default(now())

  @@unique([email, presenterId, sessionToken])
  @@index([presenterId])
  @@index([topicId])
  @@index([sessionToken])
}

model Session {
  id          String    @id @default(uuid())
  topicId     Int
  topic       Topic     @relation(fields: [topicId], references: [id], onDelete: Cascade)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  expiresAt   DateTime

  @@index([topicId, isActive, expiresAt])
}
